function renderPositions(){
  const all=[...state.positions.map(p=>({...p,_type:'open'})),...state.pendingOrders.map(p=>({...p,_type:'pending'}))];
  if(!all.length){dom.positionList.innerHTML='<div class="empty">Aucune position</div>';return;}
  dom.positionList.innerHTML=all.map(item=>{
    if(item._type==='open'){const cls=item.floatingPnl>=0?'pnl-pos':'pnl-neg';return `<div class="position-card"><div class="position-main"><div><span class="pill">${item.side==='buy'?'LONG':'SHORT'}</span> <span style="font-size:10px;color:#888;">${item.impactLabel||'—'}</span></div><div style="margin-top:4px;font-size:11px;">${item.lots}L @ ${item.entryPrice.toFixed(2)}</div><div style="margin-top:2px;font-size:10px;color:#666;">SL:${item.stopLoss?item.stopLoss.toFixed(2):'—'} | TP:${item.takeProfit?item.takeProfit.toFixed(2):'—'}</div><div class="${cls}" style="margin-top:2px;font-size:11px;">PnL: ${fmtMoney(item.floatingPnl||0)}</div></div><div style="font-size:11px;text-align:right;"><div style="color:#666;">Marge</div><div style="font-weight:900;">${fmtMoney(item.marginUsed)}</div></div><button class="secondary-btn" onclick="closePosition(${item.id})">FERMER</button></div>`;}
    return `<div class="position-card" style="border-color:${item.side==='buy'?'#12a150':'#af1f1f'};"><div class="position-main"><div><span class="pill pending-pill">⏳ ${item.type.toUpperCase()}</span><span class="pill" style="margin-left:4px;">${item.side==='buy'?'BUY':'SELL'}</span></div><div style="margin-top:4px;font-size:11px;">${item.lots}L @ ${item.triggerPrice.toFixed(2)}</div><div style="margin-top:2px;font-size:10px;color:#666;">SL:${item.stopLoss?item.stopLoss.toFixed(2):'—'} | TP:${item.takeProfit?item.takeProfit.toFixed(2):'—'}</div></div><div style="font-size:11px;text-align:right;"><div style="color:#666;">Réservée</div><div style="font-weight:900;">${fmtMoney(item.marginReserved)}</div></div><button class="secondary-btn" onclick="cancelPendingOrder(${item.id})">ANNULER</button></div>`;
  }).join('');
}

function renderAccount(){
  dom.topPortfolioValue.textContent=fmtMoney(state.equity).replace('$ ','').replace('-$ ','-');
  dom.balanceValue.textContent=fmtMoney(state.balance); dom.equityValue.textContent=fmtMoney(state.equity);
  dom.usedMarginValue.textContent=fmtMoney(state.usedMargin); dom.freeFundsValue.textContent=fmtMoney(state.freeFunds);
  dom.floatingPnlValue.textContent=fmtMoney(state.floatingPnl);
  dom.floatingPnlValue.className='stat-value '+(state.floatingPnl>=0?'pnl-pos':'pnl-neg');
  dom.spotPriceMain.textContent=fmtPrice(state.marketPrice); dom.orderPriceText.textContent=fmtPrice(state.marketPrice);
  dom.spreadText.textContent=state.spread.toFixed(3)+' $'; dom.spreadInfo.textContent=`Spread: ${state.spread.toFixed(3)} $`;
  dom.marketStateLabel.textContent=`${state.structure.phase.toUpperCase()} | Biais:${state.structure.bias.toFixed(2)}`;
  dom.sessionLabel.textContent=`Session: ${state.ict.session}${state.ict.in_killzone?' | 🔴 KZ:'+state.ict.killzone_name:''}`;
  dom.structureStateValue.textContent=state.structure.phase.substring(0,9);
  dom.fomoScoreText.textContent=state.ict.fomo.toFixed(3);
  const pm=state.playerMarketInfluence;
  dom.spotMeta.textContent=`Vol:${state.ict.vol_regime} | ATR:${state.ict.atr.toFixed(2)} | Joueur:${pm.impactLabel}${pm.isStopHuntTarget?' 🎯':''}`;
  dom.liquidityValue.textContent=fmtCompact(state.dynamicMinuteVolume)+'/min';
  dom.zoomLevel.textContent=`${state.zoomLevel.toFixed(1)}x`;
  dom.importDatasetText.textContent=`${state.importStats.datasets} ds`;
  dom.importStatusText.textContent=state.importStats.lastStatus;
  // LiqAI badge
  const mode=LiquidityAI.getMode();
  const modeLabel={bull:'🐂 BULL',bear:'🐻 BEAR',range:'↔ RANGE',trap:'🪤 TRAP'}[mode]||mode;
  dom.liqAIMode.textContent=modeLabel;
  dom.liqAIPool.textContent=`${LiquidityAI.getOrders().length} ordres (${LiquidityAI.getTriggered()} exécutés)`;
  const badge=dom.liqAIBadge; badge.textContent=modeLabel; badge.className=`liq-badge ${mode}`;
  if(LiquidityAI.getTrapPhase()==='reversal') badge.textContent='🪤 REVERSAL !';
}

function renderAll(){ updatePreview(); renderAccount(); renderPositions(); renderChart(); }

// ═══════════════════════════════════════════════════════════
// IA PRICE ACTION (local fallback + API)
// ═══════════════════════════════════════════════════════════
function computeDoubt(){
  const s=state.structure,ict=state.ict,of=state.orderflow; let d=0; const rs=[];
  if(s.phase==='uptrend'&&s.bias<-0.2){d+=0.4;rs.push('BHaussier/biais bas');}
  if(s.phase==='downtrend'&&s.bias>0.2){d+=0.4;rs.push('BBaraissier/biais haut');}
  if(s.phase==='compression'&&ict.fomo>0.20){d+=0.45;rs.push('Compression+FOMO');}
  if(of.exhaustion>0.70&&ict.consecutive_moves>8){d+=0.55;rs.push(`Épuisement ${(of.exhaustion*100).toFixed(0)}%`);}
  if(s.last_bos&&Date.now()-s.last_bos.time<5*CANDLE_INTERVAL_MS){d+=0.30;rs.push('BOS récent');}
  if(s.last_choch&&Date.now()-s.last_choch.time<8*CANDLE_INTERVAL_MS){d+=0.65;rs.push('CHoCH détecté');}
  if(ict.vol_regime==='EXPANSION'&&s.phase==='range'){d+=0.40;rs.push('Expansion en Range');}
  const eh=s.equalHighs.filter(e=>!e.swept).length,el=s.equalLows.filter(e=>!e.swept).length;
  if(eh>0||el>0){d+=0.30;rs.push(`EQH×${eh}/EQL×${el}`);}
  if(s.sweepInProgress){d+=0.45;rs.push(`Sweep ${s.sweepDir>0?'↑':'↓'}`);}
  if(s.phase!==state.ai.prevPhase){d+=0.30;rs.push(`Phase: ${state.ai.prevPhase}→${s.phase}`);state.ai.prevPhase=s.phase;}
  if(state.momentumGuard.consecutiveSameDir>MR_THRESHOLD){d+=0.35;rs.push(`Momentum ${state.momentumGuard.consecutiveSameDir}T`);}
  const liqMode=LiquidityAI.getMode();
  if(liqMode==='trap'){d+=0.40;rs.push(`LiqAI TRAP${LiquidityAI.getTrapPhase()==='reversal'?' REVERSAL !':''}`)}
  return {score:clamp(d,0,1),reasons:rs};
}

function applyLocalAI(doubts, snap){
  const atr=snap.atr,s=state.structure,mg=state.momentumGuard; let insight='',ba=0,pd=0,mr=0;
  if(mg.consecutiveSameDir>MR_THRESHOLD+2){ const rd=-mg.lastDir; insight=`Momentum freiné — reversal prévisible`; ba=rd*0.10;pd=rd*atr*0.05;mr=0.30; }
  else if(s.sweepInProgress){ insight=`Sweep ${s.sweepDir>0?'↑':'↓'} — reversal post-liq`; ba=-s.sweepDir*0.12;pd=s.sweepDir*atr*0.10; adjustDynamicVolume('sweep_IA',1.8,50); }
  else if(s.last_choch?.dir){ const dir=s.last_choch.dir; insight=`CHoCH ${dir>0?'↑':'↓'} — retournement biais`; ba=dir*0.18;pd=dir*atr*0.06;mr=0.40; adjustDynamicVolume('choch_IA',1.6,80); }
  else if(s.last_bos?.dir&&(Date.now()-s.last_bos.time)<6*CANDLE_INTERVAL_MS){ const dir=s.last_bos.dir; insight=`BOS ${dir>0?'↑':'↓'} — continuation`; ba=dir*(s.bosStrength||0.5)*0.10;pd=dir*atr*(s.bosStrength||0.5)*0.04; }
  else if(snap.inPremium&&s.supplyZones.filter(z=>!z.broken).length>0){ insight='PREMIUM+OB supply — rejet ICT'; ba=-0.12;pd=-atr*0.05;mr=0.25; }
  else if(snap.inDiscount&&s.demandZones.filter(z=>!z.broken).length>0){ insight='DISCOUNT+OB demand — rebond ICT'; ba=0.12;pd=+atr*0.05;mr=0.25; }
  else if(LiquidityAI.getMode()==='trap'){ const tp=LiquidityAI.getTrapPhase(); insight=tp==='reversal'?'LiqAI TRAP reversal actif — renversement':'LiqAI TRAP setup — piège en cours'; ba=(tp==='reversal'?-s.bias:0)*0.15; }
  else { insight=`${s.phase} | ATR:${atr.toFixed(2)} | LiqAI:${LiquidityAI.getMode()}`; }
  if(ba) state.structure.bias=clamp(state.structure.bias+ba,-1,1);
  if(pd){_injectICTPriceDelta(pd,'AI_LOCAL');state.ai.pendingImpact+=pd*0.5;}
  if(mr>0) state.ai.pendingMRBoost=clamp(state.ai.pendingMRBoost+mr,0,1.0);
  state.ai.lastInsight=insight; state.ai.confidence=0.52;
  dom.aiInsightText.textContent=insight; dom.aiConfidenceText.textContent='heuristique';
  const le={time:new Date().toLocaleTimeString('fr-FR'),insight,confidence:0.52,action:'local',doubts:doubts.slice(0,3)};
  state.ai.log.unshift(le); if(state.ai.log.length>20) state.ai.log.pop(); renderAILog();
}

async function queryAI(doubts,snap){
  if(state.ai.thinking) return; state.ai.thinking=true; dom.aiDot.className='ai-dot thinking'; dom.aiInsightText.textContent='🧠 Analyse…';
  const sys=`Tu es analyste ICT/SMC XAUUSD. Réponds JSON strict: {"insight":"1-2 phrases","confidence":0.0-1.0,"recommended_bias":-1à+1,"action":"observe|bias_up|bias_down|increase_mean_reversion","price_impact_direction":0,"volume_adjustment":1.0}`;
  const msg=`SNAPSHOT:\n${JSON.stringify(snap,null,1)}\nDOUBTS:\n${doubts.map((d,i)=>`${i+1}. ${d}`).join('\n')}`;
  try{
    const res=await fetch(state.ai.helperEndpoint,{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({text:msg,mode:'price_action_ict',snapshot:snap,doubts,system:sys})});
    if(!res.ok) throw new Error(`HTTP ${res.status}`);
    const data=await res.json(); let parsed=null;
    const raw=data.raw_text||data.content||''; if(raw){try{const m=raw.match(/\{[\s\S]*\}/);if(m) parsed=JSON.parse(m[0]);}catch(e){}}
    if(data.insight||data.confidence!=null) parsed=data;
    if(parsed){
      const insight=parsed.insight||'Signal';const conf=Number(parsed.confidence)||0.5;const rb=Number(parsed.recommended_bias??0);const act=parsed.action||'observe';const pid=Number(parsed.price_impact_direction??0);const va=Number(parsed.volume_adjustment??1.0);
      state.ai.lastInsight=insight;state.ai.confidence=conf;
      if(act!=='observe') state.structure.bias=clamp(state.structure.bias*0.65+rb*0.35,-1,1);
      const atr=state.ict.atr;
      if(pid!==0){_injectICTPriceDelta(pid*atr*0.08*conf,'AI_API');state.ai.pendingImpact+=pid*atr*0.04*conf;}
      if(va!==1.0) adjustDynamicVolume('AI_API_vol',clamp(va,0.5,3.0),60);
      dom.aiInsightText.textContent=insight;dom.aiConfidenceText.textContent=`${(conf*100).toFixed(0)}%`;dom.aiDot.className='ai-dot answered';
      state.ai.log.unshift({time:new Date().toLocaleTimeString('fr-FR'),insight,confidence:conf,action:act,doubts:doubts.slice(0,3)});
      if(state.ai.log.length>20) state.ai.log.pop();renderAILog();
    } else {applyLocalAI(doubts,snap);dom.aiDot.className='ai-dot idle';}
  }catch(err){applyLocalAI(doubts,snap);dom.aiDot.className='ai-dot idle';}
  finally{state.ai.thinking=false;state.ai.lastQueryTick=state.tickCount;setTimeout(()=>dom.aiDot.className='ai-dot idle',8000);}
}

function renderAILog(){ if(!state.ai.log.length){dom.aiLog.innerHTML='';return;} dom.aiLog.innerHTML=state.ai.log.map(e=>`<div class="ai-log-entry"><span style="color:#888;font-size:9px;">[${e.time}]</span> <span style="font-weight:900;">${(e.action||'?').toUpperCase()}</span> <span style="color:#2563eb;">${(e.confidence*100).toFixed(0)}%</span><br/><span>${e.insight}</span>${e.doubts?.length?`<div style="color:#888;font-size:9px;margin-top:2px;">${e.doubts.map(d=>`• ${d}`).join('<br/>')}</div>`:''}</div>`).join(''); }

function checkAI(){
  if(state.tickCount-state.ai.lastQueryTick<state.ai.queryInterval||state.ai.thinking) return;
  const {score,reasons}=computeDoubt(); state.ai.conflictScore=score;
  if(score>=0.42&&reasons.length>0){
    const snap={price:state.marketPrice,phase:state.structure.phase,bias:state.structure.bias,atr:state.ict.atr,vol_regime:state.ict.vol_regime,session:state.ict.session,fomo:state.ict.fomo,consecutive_moves:state.ict.consecutive_moves,last_bos:state.structure.last_bos,last_choch:state.structure.last_choch,sweep_active:state.structure.sweepInProgress,liqAI_mode:LiquidityAI.getMode(),liqAI_orders:LiquidityAI.getOrders().length,inPremium:state.marketPrice>state.structure.premium,inDiscount:state.marketPrice<state.structure.discount};
    queryAI(reasons,snap);
  }
}

// ═══════════════════════════════════════════════════════════
// SESSION & KILLZONES
// ═══════════════════════════════════════════════════════════
function updateClock(){ const now=new Date(); dom.clockBox.textContent=now.toLocaleTimeString('fr-FR',{hour:'2-digit',minute:'2-digit',second:'2-digit'}); const h=now.getHours(); if(h>=22||h<7){state.sessionBias=0.70;state.ict.session='ASIA';state.ict.in_killzone=false;state.ict.killzone_name='';} else if(h>=7&&h<13){state.sessionBias=1.15;state.ict.session='LONDON';state.ict.in_killzone=(h>=7&&h<10)||(h>=11&&h<12);state.ict.killzone_name=h>=7&&h<10?'London Open':h>=11&&h<12?'London Close':'';} else if(h>=13&&h<17){state.sessionBias=1.30;state.ict.session='NY_OPEN';state.ict.in_killzone=h>=13&&h<16;state.ict.killzone_name=h>=13&&h<16?'NY AM Session':'';} else{state.sessionBias=1.05;state.ict.session='OVERLAP';state.ict.in_killzone=h>=16&&h<18;state.ict.killzone_name=h>=16&&h<18?'NY PM Session':'';} if(state.ict.in_killzone) state.sessionBias*=1.12; }

// ═══════════════════════════════════════════════════════════
// CONTRÔLES UI
// ═══════════════════════════════════════════════════════════
function setupControls(){
  dom.leverageChips.innerHTML=LEVERAGES.map(l=>`<button class="lev-chip ${l===state.selectedLeverage?'active':''}" data-lev="${l}">${l===1?'1x':l+'x'}</button>`).join('');
  dom.leverageChips.addEventListener('click',e=>{const b=e.target.closest('[data-lev]');if(!b) return;state.selectedLeverage=Number(b.dataset.lev);document.querySelectorAll('.lev-chip').forEach(c=>c.classList.remove('active'));b.classList.add('active');updatePreview();});
  dom.buyBtn.addEventListener('click',()=>setDir('buy')); dom.sellBtn.addEventListener('click',()=>setDir('sell'));
  document.querySelectorAll('[data-direction]').forEach(b=>b.addEventListener('click',()=>setDir(b.dataset.direction)));
  [dom.orderTypeMarket,dom.orderTypeLimit,dom.orderTypeStop,dom.orderTypeStopLimit].forEach(btn=>btn.addEventListener('click',()=>{state.orderType=btn.dataset.otype;[dom.orderTypeMarket,dom.orderTypeLimit,dom.orderTypeStop,dom.orderTypeStopLimit].forEach(b=>b.classList.remove('active'));btn.classList.add('active');const ip=state.orderType!=='market';dom.pendingPriceField.classList.toggle('show',ip);dom.pendingPriceLabel.textContent=state.orderType==='limit'?'Prix Limite':state.orderType==='stop'?'Prix Stop':'Prix Stop-Limite';dom.openPositionBtn.textContent=ip?`PLACER ${state.orderType.toUpperCase()}`:'OUVRIR';updatePreview();}));
  dom.pendingPriceInput.addEventListener('input',()=>{state.pendingPrice=Number(dom.pendingPriceInput.value)||null;updatePreview();});
  dom.maxLotBtn.addEventListener('click',()=>{dom.lotsInput.value=((state.freeFunds*state.selectedLeverage)/(CONTRACT_SIZE_OZ*state.marketPrice)).toFixed(2);updatePreview();});
  [dom.lotsInput,dom.slInput,dom.tpInput].forEach(el=>el.addEventListener('input',updatePreview));
  dom.openPositionBtn.addEventListener('click',()=>{if(state.orderType==='market') openPosition(); else placePendingOrder();});
  dom.closeAllBtn.addEventListener('click',closeAllPositions);
  dom.depositBtn.addEventListener('click',()=>{const a=Number(dom.fundsInput.value);if(a>0){state.balance+=a;recalcAccount();renderAll();showToast(`+${fmtMoney(a)}`);}});
  dom.withdrawBtn.addEventListener('click',()=>{const a=Number(dom.fundsInput.value);if(a>0&&a<=state.freeFunds){state.balance-=a;recalcAccount();renderAll();showToast(`-${fmtMoney(a)}`);}else showToast('Fonds insuffisants');});
  dom.resetBtn.addEventListener('click',()=>{state.balance=INITIAL_BALANCE;state.positions=[];state.pendingOrders=[];state.nextPositionId=1;state.nextPendingId=1;state.panic={level:0,direction:0,duration:0,triggered:false,cooldown:0,reversion_force:0};state.structure.equalHighs=[];state.structure.equalLows=[];state.structure.demandZones=[];state.structure.supplyZones=[];state.structure.sweepInProgress=false;state.structure.ictPriceDelta=0;state.ai.pendingImpact=0;state.ai.pendingMRBoost=0;state.ai.pendingBiasAdjust=0;state.ict.fomo=0;dom.panicBar.classList.remove('show');buildInitialCandles();recalcAccount();renderAll();showToast('🔄 Reset');});
  dom.zoomInBtn.addEventListener('click',()=>{state.zoomLevel=Math.min(state.zoomLevel+0.2,4.0);state.visibleCandlesCount=Math.max(20,Math.floor(64/state.zoomLevel));state.chartViewport.initialized=false;initViewport();renderAll();});
  dom.zoomOutBtn.addEventListener('click',()=>{state.zoomLevel=Math.max(state.zoomLevel-0.2,0.5);state.visibleCandlesCount=Math.max(20,Math.floor(64/state.zoomLevel));state.chartViewport.initialized=false;initViewport();renderAll();});
  dom.pickLocalFilesBtn.addEventListener('click',()=>dom.localFileInput.click());
  dom.useDefaultProfileBtn.addEventListener('click',()=>{applyProfile({...DEFAULT_PROFILE,source:'Défaut'});showToast('Profil défaut');});
  dom.localFileInput.addEventListener('change',async()=>{const files=[...dom.localFileInput.files||[]].filter(f=>['.csv','.xlsx','.xls','.zip'].some(e=>f.name.toLowerCase().endsWith(e)));if(!files.length) return showToast('Format non supporté');dom.importStatusText.textContent=`Lecture ${files.length} fichier(s)…`;state.importedDatasets=[];state.importStats={filesScanned:files.length,datasets:0,candlesBuilt:0,lastStatus:'Lecture…'};for(const file of files){try{const ds=await parseLocalFile(file);for(const d of ds)if(d?.candles?.length){state.importedDatasets.push(d);state.importStats.candlesBuilt+=d.candles.length;}}catch(err){console.error(err);}} state.importStats.datasets=state.importedDatasets.length;refreshImportContext();if(state.importedDatasets.length>0){const p=mergeProfiles(state.importedDatasets);applyProfile({...p,source:`calibré (${state.importedDatasets.length} ds)`});showToast(`✅ ${state.importedDatasets.length} ds chargés`);}else{dom.importStatusText.textContent='Aucune donnée XAUUSD';showToast('Aucune donnée XAUUSD');}renderAll();});
  dom.aiLogToggleBtn.addEventListener('click',()=>{const v=dom.aiLog.classList.toggle('visible');dom.aiLogToggleBtn.textContent=v?'Masquer':'Log';});
  dom.canvas.addEventListener('mousemove',e=>{const r=dom.canvas.getBoundingClientRect();state.crosshair.active=true;state.crosshair.x=e.clientX-r.left;state.crosshair.y=e.clientY-r.top;renderChart();});
  dom.canvas.addEventListener('mouseleave',()=>{state.crosshair.active=false;renderChart();});
  window.addEventListener('resize',()=>{resizeCanvas();renderChart();});
}
function setDir(d){state.direction=d;dom.buyBtn.classList.toggle('active',d==='buy');dom.sellBtn.classList.toggle('active',d==='sell');document.querySelectorAll('[data-direction]').forEach(b=>b.classList.toggle('active',b.dataset.direction===d));updatePreview();}

// ═══════════════════════════════════════════════════════════
// BOUCLE PRINCIPALE
// ═══════════════════════════════════════════════════════════
function tick(){stepPrice();applyStopLosses();checkPendingOrders();recalcAccount();updateViewportSmooth();checkAI();renderAll();}
function tickCandle(){closeCurrentCandle();updateViewportSmooth();renderAll();}

function boot(){
  resizeCanvas(); setupControls(); updateClock();
  applyProfile({...DEFAULT_PROFILE,source:'Défaut'});
  recalcAccount(); renderAll();
  state.timers.push(setInterval(updateClock,1000));
  state.timers.push(setInterval(tick,TICK_INTERVAL_MS));
  state.timers.push(setInterval(tickCandle,CANDLE_INTERVAL_MS));
  dom.aiInsightText.textContent='v6.3 — LiqAI actif | Impact joueur illimité | 4 cycles de liquidité';
  dom.aiConfidenceText.textContent='prêt';
  showToast('🚀 v6.3 — LiqAI: BSL/SSL/OB/FVG/TRAP | Impact lot proportionnel sans limite');
}
boot();

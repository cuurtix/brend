function updatePanic(){ const pk=state.panic,ict=state.ict,of=state.orderflow; if(pk.cooldown>0){pk.cooldown--;return;} if(!pk.triggered&&Math.abs(ict.consecutive_moves)/11>0.90&&ict.fomo>0.22&&ict.vol_regime==='EXPANSION'){ pk.triggered=true; pk.level=clamp(Math.abs(ict.consecutive_moves)/11*0.60+ict.fomo*0.20,0.15,0.55); pk.direction=ict.last_move_dir; pk.duration=Math.round(5+Math.random()*8); pk.reversion_force=0; dom.panicBar.textContent=pk.direction>0?'⚡ PANIC BUY — Liquidation':'⚡ PANIC SELL — Stops chassés'; dom.panicBar.classList.add('show'); showToast(pk.direction>0?'⚡ PANIC BUY !':'⚡ PANIC SELL !'); adjustDynamicVolume('panic',1.6+pk.level,50); } if(pk.triggered){ pk.duration--; pk.reversion_force=clamp(pk.reversion_force+0.06*(1-of.bid_depth[0]*of.ask_depth[0]),0,0.85); pk.level*=0.91; if(pk.duration<=0||pk.level<0.03){ pk.triggered=false;pk.level=0;pk.reversion_force=0; pk.cooldown=60+Math.round(Math.random()*60); dom.panicBar.classList.remove('show'); const rev=-pk.direction; _injectICTPriceDelta(rev*state.ict.atr*0.30,'PANIC_REV'); of.pending_impact+=rev*state.ict.atr*0.40; state.structure.bias=clamp(state.structure.bias+rev*0.15,-1,1); adjustDynamicVolume('panic_end',0.80,120); } } else { pk.level=Math.max(0,pk.level-0.003); if(pk.level<=0) dom.panicBar.classList.remove('show'); } }

// ═══════════════════════════════════════════════════════════
// MOTEUR DE PRIX — LiqAI intégré
// ═══════════════════════════════════════════════════════════
function stepPrice(){
  updateICTMetrics(); updateFomo(); updateOrderBook(); updatePanic(); updateMarketStructure(); decayDynamicVolume();
  updatePlayerInfluence();

  const atrFloor = computeAtrFloor();
  const atr = Math.max(state.ict.atr, atrFloor);
  const price = state.currentCandle.close;
  const pk = state.panic, of = state.orderflow, s = state.structure;

  // ── ICT accumulé ──────────────────────────────────────
  const ictEff = clamp(s.ictPriceDelta*(1-s.ictDecayFactor), -atr*TICK_SCALE*0.55, atr*TICK_SCALE*0.55);
  s.ictPriceDelta *= s.ictDecayFactor;

  // ── IA Price Action ───────────────────────────────────
  const aiEff = state.ai.pendingImpact*0.12; state.ai.pendingImpact*=0.88;
  state.ai.pendingBiasAdjust*=0.92; state.ai.pendingMRBoost*=0.94;

  // ── Drift & MR ────────────────────────────────────────
  const phaseDrift = s.phase==='uptrend'?+atr*0.007:s.phase==='downtrend'?-atr*0.007:s.phase==='expansion'?+atr*0.005*Math.sign(s.bias):0;
  const structDrift = s.bias*atr*0.005*DRIFT_SCALE;
  const distEq = price-s.equilibrium;
  const mrTheta = 0.006*(1+Math.abs(distEq/Math.max(atr*5,0.01))*0.5)*(1+(state.ai.pendingMRBoost||0)*0.8);
  const mr = -distEq*mrTheta*DRIFT_SCALE;
  let pdR = 0; if(price>s.premium) pdR=-(price-s.premium)*0.004*DRIFT_SCALE; if(price<s.discount) pdR=-(price-s.discount)*0.004*DRIFT_SCALE;

  // ── Magnétismes ───────────────────────────────────────
  const fvgMag = computeFVGMag(), liqMag = computeLiqMag(), obMag = computeOBMag();

  // ── IA Liquidité — pression des ordres simulés ────────
  // LiquidityAI.tick() retourne la pression nette de tous ses ordres
  // Les ordres ont une taille réelle → impact proportionnel au lot/volume
  const liqAIPressure = LiquidityAI.tick(state);

  // ── Détection: l'algo détecte les ordres en attente volumineux ──
  // Si un ordre LiqAI est proche ET gros → le moteur accélère vers lui
  let liqAIAttraction = 0;
  for(const o of LiquidityAI.getOrders()) {
    const dist = Math.abs(o.price - price);
    const norm = dist / Math.max(atr, 0.01);
    if(norm > 3) continue;
    const notional = o.lots * CONTRACT_SIZE_OZ * o.price;
    const volR = notional / Math.max(state.dynamicDailyVolume, 1);
    // Attraction = √(volRatio) × ATR × TICK_SCALE × e^(-distance) — sans limite de lot
    const attraction = Math.sqrt(volR) * atr * TICK_SCALE * Math.exp(-norm * 0.6) * 0.25;
    liqAIAttraction += (o.price > price ? 1 : -1) * attraction;
  }
  // Même logique pour les ordres en attente du JOUEUR (si gros)
  let playerPendingAttraction = 0;
  for(const po of state.pendingOrders) {
    const dist = Math.abs(po.price - price);
    const norm = dist / Math.max(atr, 0.01);
    if(norm > 3) continue;
    const notional = po.lots * CONTRACT_SIZE_OZ * (po.triggerPrice || price);
    const volR = notional / Math.max(state.dynamicDailyVolume, 1);
    if(volR < IMPACT_MARGINAL) continue; // trop petit → ignoré
    const attraction = Math.sqrt(volR) * atr * TICK_SCALE * Math.exp(-norm * 0.6) * 0.35;
    playerPendingAttraction += (po.price > price ? 1 : -1) * attraction;
  }

  // ── Bruit gaussien ────────────────────────────────────
  const vf = state.ict.vol_regime==='EXPANSION'?0.55:state.ict.vol_regime==='HIGH'?0.43:state.ict.vol_regime==='LOW'?0.20:state.ict.vol_regime==='COMPRESSION'?0.11:0.30;
  const noise = clamp(gaussian(),-2.5,2.5) * atr * vf * state.sessionBias * TICK_SCALE * clamp(Math.sqrt(getVolRatio()),0.6,1.8);

  // ── Order flow ────────────────────────────────────────
  const ofD = (of.buy_pressure-of.sell_pressure)*atr*0.003; of.pending_impact*=0.93;

  // ── Panic ─────────────────────────────────────────────
  let pkD = 0; if(pk.triggered&&pk.level>0.03) pkD = pk.direction*pk.level*atr*0.022 - pk.direction*pk.reversion_force*atr*0.015;

  // ── Épuisement ────────────────────────────────────────
  const consRev = -(state.ict.last_move_dir||0)*of.exhaustion*atr*0.006;

  // ── OTE magnet ────────────────────────────────────────
  let oteM = 0; if(state.ict.ote_level){ const d=state.ict.ote_level-price; if(Math.abs(d)/Math.max(atr,0.01)<1.5) oteM=d*0.0025; }

  // ── Joueur: impact illimité proportionnel au lot ──────
  const playerPressure = computePlayerPricePressure();
  const playerHuntDelta = attemptPlayerStopHunt();

  // ── Assemblage avant frein ────────────────────────────
  const beforeBrake = phaseDrift+structDrift+mr+pdR+fvgMag+liqMag+obMag
    +noise+ofD+of.pending_impact+pkD+consRev+oteM
    +ictEff+aiEff+playerPressure+playerHuntDelta
    +liqAIPressure    // Pression magnétique des ordres LiqAI
    +liqAIAttraction  // Attraction vers les gros ordres LiqAI
    +playerPendingAttraction; // Attraction vers les gros ordres joueur en attente

  updateMomentumGuard(beforeBrake);
  const brake = computeMomentumBrake();
  let delta = beforeBrake + brake;

  // Anti-stall
  updateVolGuard(Math.abs(delta), atr);
  const as = antiStall(atr);
  if(as!==0) delta += as;

  // Clamp tick max — mais le joueur whale peut dépasser légèrement
  const playerBoost = Math.min(computePlayerExposure() / IMPACT_MODERATE, 3.0);
  const maxTick = atr * TICK_SCALE * (pk.triggered?1.05:MAX_TICK_ATR) * (1 + playerBoost * 0.15);
  delta = clamp(delta, -maxTick, maxTick);

  const newClose = Math.max(100, price+delta);
  const dir = newClose>=price?1:-1;
  dir===state.ict.last_move_dir
    ? (state.ict.consecutive_moves=Math.min(state.ict.consecutive_moves+1,MAX_CONSEC))
    : (state.ict.consecutive_moves=Math.max(0,state.ict.consecutive_moves-2), state.ict.last_move_dir=dir);

  // Mèches
  const prof=state.referenceProfile; const ff=1+state.ict.fomo*0.20;
  const upperWick=Math.max(0,(atr*(prof.upperWickRatio||0.24))*ff*(-Math.log(Math.max(Math.random(),0.0001)))*TICK_SCALE*(pk.triggered&&pk.direction>0?1.35:1));
  const lowerWick=Math.max(0,(atr*(prof.lowerWickRatio||0.24))*ff*(-Math.log(Math.max(Math.random(),0.0001)))*TICK_SCALE*(pk.triggered&&pk.direction<0?1.35:1));
  state.currentCandle.close=newClose;
  const mx3=atr*3.0,co=state.currentCandle.open;
  state.currentCandle.high=clamp(Math.max(state.currentCandle.high,newClose+upperWick),co-mx3,co+mx3);
  state.currentCandle.low =clamp(Math.min(state.currentCandle.low, newClose-lowerWick),co-mx3,co+mx3);
  state.marketPrice=newClose;

  const tr=state.currentCandle.high-state.currentCandle.low;
  const eff=Math.max(tr,atrFloor*0.20);
  state.ict.atr      =Math.max(atrFloor*0.88, state.ict.atr*(1-1/8)+eff*(1/8));
  state.ict.atr_slow =Math.max(atrFloor*0.95, state.ict.atr_slow*(1-1/20)+eff*(1/20));
  state.tickCount++;
}

function closeCurrentCandle(){ const c=state.currentCandle; c.high=Math.max(c.high,c.open,c.close); c.low=Math.min(c.low,c.open,c.close); if(!Number.isFinite(c.high)||!Number.isFinite(c.low)||c.high<c.low){ c.high=Math.max(c.open,c.close)+0.01; c.low=Math.min(c.open,c.close)-0.01; } const body=Math.abs(c.close-c.open),range=c.high-c.low,br=state.referenceProfile.bodyRatio||0.52; if(range>0&&body/range>0.95){ const ext=body*(0.95-br)*0.5; c.high+=ext; c.low-=ext; } state.candles.push({...c}); if(state.candles.length>MAX_CANDLES_STORED) state.candles.shift(); const mg=state.momentumGuard; mg.anchorPrice=state.marketPrice; mg.cumulMoveFromAnchor*=0.50; state.regime.age++; if(state.regime.age>=state.regime.max_age){ const cys=['balance','accumulation','distribution','expansion_up','expansion_down'],ws=[0.30,0.20,0.20,0.15,0.15]; let r=Math.random(),cum=0,ch='balance'; for(let i=0;i<cys.length;i++){cum+=ws[i];if(r<cum){ch=cys[i];break;}} state.regime.cycle=ch; state.regime.age=0; state.regime.max_age=18+Math.round(Math.random()*24); const bm={expansion_up:0.20,expansion_down:-0.20,accumulation:0.07,distribution:-0.07}; if(bm[ch]) state.structure.bias=clamp(state.structure.bias+bm[ch],-1,1); const vm={expansion_up:1.6,expansion_down:1.6,accumulation:1.15,distribution:1.20,balance:0.90}; adjustDynamicVolume('regime_'+ch,vm[ch]||1.0,state.regime.max_age*TICKS_PER_CANDLE); } state.currentCandle={open:state.marketPrice,high:state.marketPrice,low:state.marketPrice,close:state.marketPrice,time:Date.now()+CANDLE_INTERVAL_MS}; checkPendingOrders(); }


function parseCSV(text){ const lines=text.split(/\r?\n/).filter(Boolean); if(!lines.length) return []; const sep=lines[0].includes(';')?';':lines[0].includes('\t')?'\t':','; const h=lines[0].split(sep).map(x=>x.trim().replace(/^["']|["']$/g,'')); return lines.slice(1).map(l=>{ const p=l.split(sep); const r={}; h.forEach((k,i)=>r[k]=(p[i]||'').trim().replace(/^["']|["']$/g,'')); return r; }); }

function fmtPrice(v){ return `$ ${Number(v).toFixed(PRICE_DECIMALS)}`; }
function fmtMoney(v){ const s=v<0?'-$ ':'$ '; return `${s}${Math.abs(v).toLocaleString('en-US',{minimumFractionDigits:2,maximumFractionDigits:2})}`; }
function fmtCompact(v){ const a=Math.abs(v); if(a>=1e9) return `${(v/1e9).toFixed(1)}B`; if(a>=1e6) return `${(v/1e6).toFixed(0)}M`; if(a>=1e3) return `${(v/1e3).toFixed(1)}K`; return v.toFixed(2); }
function clamp(v,mn,mx){ return Math.max(mn,Math.min(mx,v)); }
function rand(mn,mx){ return Math.random()*(mx-mn)+mn; }
function median(arr){ if(!arr.length) return 0; const s=[...arr].sort((a,b)=>a-b); const m=Math.floor(s.length/2); return s.length%2?s[m]:(s[m-1]+s[m])/2; }
function mean(arr){ return arr.length?arr.reduce((a,b)=>a+b,0)/arr.length:0; }
function gaussian(){ let u=0,v=0; while(!u) u=Math.random(); while(!v) v=Math.random(); return Math.sqrt(-2*Math.log(u))*Math.cos(2*Math.PI*v); }
function showToast(msg){ clearTimeout(state.toastTimer); dom.toast.textContent=msg; dom.toast.classList.add('show'); state.toastTimer=setTimeout(()=>dom.toast.classList.remove('show'),2600); }
function ema(p,c,a){ return p*(1-a)+c*a; }
function classifyImpact(r){
  if(r < IMPACT_NONE)     return 'invisible';
  if(r < IMPACT_MARGINAL) return 'marginal';
  if(r < IMPACT_WEAK)     return 'faible';
  if(r < IMPACT_MODERATE) return 'modéré';
  if(r < 0.001)           return 'fort';
  if(r < 0.005)           return 'MASSIF';
  return '🐋 WHALE';
}


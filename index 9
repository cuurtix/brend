function updateFomo(){ const ict=state.ict; const recent=state.candles.slice(-4); let imp=0; if(recent.length>=2){ const lc=recent[recent.length-1]; const rng=Math.max(lc.high-lc.low,0.001); const body=Math.abs(lc.close-lc.open); if(body/rng>0.65&&ict.consecutive_moves>9&&ict.vol_regime==='EXPANSION') imp=clamp((body/rng-0.65)*0.8+(ict.consecutive_moves-9)*0.02,0,0.20); } ict.fomoTicksSinceImpulse=Math.min(ict.fomoTicksSinceImpulse+(imp>0?-ict.fomoTicksSinceImpulse:1),9999); const dec=Math.exp(-1/25); ict.fomo=clamp(imp>0?Math.min(ict.fomo*dec+imp*0.06,FOMO_CAP):ict.fomo*dec,0,FOMO_CAP); if(ict.fomoTicksSinceImpulse>100) ict.fomo*=0.90; }


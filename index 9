<script>
'use strict';
// ═══════════════════════════════════════════════════════════
// CONSTANTES
// ═══════════════════════════════════════════════════════════
const CONTRACT_SIZE_OZ   = 100;
const TICK_INTERVAL_MS   = 250;
const CANDLE_INTERVAL_MS = 60_000;
const TICKS_PER_CANDLE   = CANDLE_INTERVAL_MS / TICK_INTERVAL_MS;
const DRIFT_SCALE        = TICK_INTERVAL_MS / CANDLE_INTERVAL_MS;
const TICK_SCALE         = Math.sqrt(TICK_INTERVAL_MS / CANDLE_INTERVAL_MS);
const INITIAL_BALANCE    = 10_000;
const MAX_CANDLES_STORED = 512;
const START_PRICE        = 3_320;
const LEVERAGES          = [1,10,50,100,500];
const PRICE_DECIMALS     = 2;
const XAUUSD_BASE_DAILY  = 180_000_000_000;
const XAUUSD_BASE_MIN    = XAUUSD_BASE_DAILY / 1440;

// Impact joueur: ratio linéaire sans cap — plus le lot est gros, plus l'impact est fort
// σ_price_impact = k_permanent × (notionnel/vol_jour) × prix + k_temp × ATR × √(notionnel/vol_jour)
const K_PERM = 0.15;   // impact permanent (slippage permanent)
const K_TEMP = 0.80;   // impact temporaire (slippage de marché)

// Seuils d'affichage uniquement (pas de cap d'impact)
const IMPACT_NONE     = 0.000005;
const IMPACT_MARGINAL = 0.00002;
const IMPACT_WEAK     = 0.0001;
const IMPACT_MODERATE = 0.0005;
// > 0.001 = STRONG, > 0.005 = MASSIVE, > 0.01 = WHALE

const MAX_CONSEC   = 18;
const MR_THRESHOLD = 14;
const MAX_TICK_ATR = 0.55;
const FOMO_CAP     = 0.35;
const STOP_HUNT_BASE = 0.0008;

const DEFAULT_PROFILE = {
  source:'default', midPrice:START_PRICE, sigma1mPct:0.00038,
  wickRatio:0.48, bodyRatio:0.52, medianSpread:0.18,
  trendPersistence:0.54, orderFlowBias:0,
  liquidityUSD:XAUUSD_BASE_MIN, median1mQuoteVolume:XAUUSD_BASE_MIN,
  avgRun:5.0, microNoise:0.18, profileStrength:0.4,
  upperWickRatio:0.24, lowerWickRatio:0.24, dailyATRTarget:18.0,
};

// ═══════════════════════════════════════════════════════════
// IA LIQUIDITÉ — CYCLES & ORDRES SIMULÉS
// ═══════════════════════════════════════════════════════════
// 4 modes: 'bull' | 'bear' | 'range' | 'trap'
// L'IA place des ordres simulés (BSL/SSL) aux points de structure ICT
// pour que l'algo aille les chercher et délivre un beau prix.
// Les ordres ont une taille réelle → impactent le prix proportionnellement
// au volume journalier, sans limite de lot.

const LiquidityAI = (() => {
  const MODES = ['bull','bear','range','trap'];
  // Durée min/max en bougies avant changement de mode
  const MODE_DURATION = { bull:[8,20], bear:[8,20], range:[6,15], trap:[4,10] };
  // Taille des ordres simulés (en lots): [min, max]
  const ORDER_LOTS = { bull:[50,800], bear:[50,800], range:[30,400], trap:[20,300] };

  let _mode = 'range';
  let _modeAge = 0;
  let _modeDuration = 12;
  let _orders = []; // {id, side, lots, price, type:'bsl'|'ssl'|'ob'|'fvg'|'inducement', triggered, tickCreated}
  let _nextId = 1;
  let _lastPlaceTick = -999;
  let _placeCooldown = 8; // bougies entre placements
  let _totalTriggered = 0;
  let _trapPhase = 'setup'; // 'setup' | 'reversal'

  function pickMode(s) {
    // Transition logique selon le biais actuel
    const bias = s.structure.bias;
    const phase = s.structure.phase;
    // Après un trap, on revient à bull/bear selon le biais
    if(_mode === 'trap' && _modeAge > _modeDuration * 0.6) {
      return bias > 0.15 ? 'bull' : bias < -0.15 ? 'bear' : 'range';
    }
    const weights = {
      bull  : Math.max(0.05, 0.30 + bias * 0.25 + (phase==='uptrend'?0.15:0)),
      bear  : Math.max(0.05, 0.30 - bias * 0.25 + (phase==='downtrend'?0.15:0)),
      range : Math.max(0.05, 0.25 + (phase==='range'||phase==='compression'?0.15:0) - Math.abs(bias)*0.1),
      trap  : Math.max(0.05, 0.15 + (s.ict.fomo>0.18?0.10:0)),
    };
    const total = Object.values(weights).reduce((a,b)=>a+b,0);
    let r = Math.random() * total, cum = 0;
    for(const [m,w] of Object.entries(weights)) { cum += w; if(r < cum) return m; }
    return 'range';
  }

  function lotRange(mode) {
    const [mn,mx] = ORDER_LOTS[mode];
    return mn + Math.random() * (mx - mn);
  }

  function placeBullOrders(s) {
    // Mode bull: on place SSL (sell-side liquidity = stops sous les bas) pour que
    // l'algo sweep et remonte; + BSL (buy-side au dessus des highs) comme objectif
    const price = s.marketPrice, atr = s.ict.atr;
    const orders = [];
    // SSL: achats groupés juste sous les lows récents (demand zones)
    const swLow = s.structure.swingLow;
    orders.push({
      id:_nextId++, side:'buy', lots:lotRange('bull'),
      price: swLow - atr * (0.05 + Math.random()*0.15),
      type:'ssl', triggered:false, tickCreated:s.tickCount,
    });
    // BSL: ordres d'achat en attente aux EQH (cibles haussières)
    for(const eh of s.structure.equalHighs.filter(e=>!e.swept&&e.price>price).slice(0,2)) {
      orders.push({
        id:_nextId++, side:'buy', lots:lotRange('bull')*0.5,
        price: eh.price - atr * 0.05, // juste sous l'EQH (stop limit)
        type:'bsl', triggered:false, tickCreated:s.tickCount,
      });
    }
    // OB demand: ordres d'achat sur la demand zone la plus proche
    const dz = s.structure.demandZones.filter(z=>!z.broken&&z.high<price).slice(-1)[0];
    if(dz) orders.push({
      id:_nextId++, side:'buy', lots:lotRange('bull'),
      price: dz.mid, type:'ob', triggered:false, tickCreated:s.tickCount,
    });
    return orders;
  }

  function placeBearOrders(s) {
    const price = s.marketPrice, atr = s.ict.atr;
    const orders = [];
    const swHigh = s.structure.swingHigh;
    orders.push({
      id:_nextId++, side:'sell', lots:lotRange('bear'),
      price: swHigh + atr * (0.05 + Math.random()*0.15),
      type:'bsl', triggered:false, tickCreated:s.tickCount,
    });
    for(const el of s.structure.equalLows.filter(e=>!e.swept&&e.price<price).slice(0,2)) {
      orders.push({
        id:_nextId++, side:'sell', lots:lotRange('bear')*0.5,
        price: el.price + atr * 0.05,
        type:'ssl', triggered:false, tickCreated:s.tickCount,
      });
    }
    const sz = s.structure.supplyZones.filter(z=>!z.broken&&z.low>price).slice(0,1)[0];
    if(sz) orders.push({
      id:_nextId++, side:'sell', lots:lotRange('bear'),
      price: sz.mid, type:'ob', triggered:false, tickCreated:s.tickCount,
    });
    return orders;
  }

  function placeRangeOrders(s) {
    const price = s.marketPrice, atr = s.ict.atr;
    const eq = s.structure.equilibrium;
    const orders = [];
    // Acheteurs en discount, vendeurs en premium — pour canaliser le range
    orders.push({
      id:_nextId++, side:'buy', lots:lotRange('range'),
      price: s.structure.discount - atr * 0.08,
      type:'ssl', triggered:false, tickCreated:s.tickCount,
    });
    orders.push({
      id:_nextId++, side:'sell', lots:lotRange('range'),
      price: s.structure.premium + atr * 0.08,
      type:'bsl', triggered:false, tickCreated:s.tickCount,
    });
    // Liquidité à l'équilibre (FVG mitigation)
    for(const fvg of s.ict.active_fvgs.slice(0,2)) {
      orders.push({
        id:_nextId++, side: fvg.dir>0 ? 'buy':'sell',
        lots: lotRange('range')*0.4,
        price: fvg.mid, type:'fvg', triggered:false, tickCreated:s.tickCount,
      });
    }
    return orders;
  }

  function placeTrapOrders(s) {
    // Inducement: faux breakout — on place des ordres qui poussent le prix CONTRE la tendance
    // puis on prépare des ordres dans le sens réel (piège retail)
    const price = s.marketPrice, atr = s.ict.atr;
    const orders = [];
    _trapPhase = 'setup';
    // Phase 1: inducement haussier (pour piéger les acheteurs)
    if(s.structure.bias >= 0) {
      // Acheteurs au dessus du high → faux breakout
      orders.push({
        id:_nextId++, side:'buy', lots:lotRange('trap'),
        price: s.structure.swingHigh + atr * (0.1 + Math.random()*0.2),
        type:'inducement', triggered:false, tickCreated:s.tickCount,
      });
      // Puis vendeurs massifs juste au dessus → sweep et reversal
      orders.push({
        id:_nextId++, side:'sell', lots:lotRange('trap')*1.8,
        price: s.structure.swingHigh + atr * (0.25 + Math.random()*0.3),
        type:'inducement', triggered:false, tickCreated:s.tickCount,
      });
    } else {
      orders.push({
        id:_nextId++, side:'sell', lots:lotRange('trap'),
        price: s.structure.swingLow - atr * (0.1 + Math.random()*0.2),
        type:'inducement', triggered:false, tickCreated:s.tickCount,
      });
      orders.push({
        id:_nextId++, side:'buy', lots:lotRange('trap')*1.8,
        price: s.structure.swingLow - atr * (0.25 + Math.random()*0.3),
        type:'inducement', triggered:false, tickCreated:s.tickCount,
      });
    }
    return orders;
  }

  function placeOrders(s) {
    const newOrders = _mode==='bull'  ? placeBullOrders(s)
                    : _mode==='bear'  ? placeBearOrders(s)
                    : _mode==='range' ? placeRangeOrders(s)
                    : placeTrapOrders(s);
    _orders.push(...newOrders);
    // Nettoyage: max 40 ordres LiqAI
    if(_orders.length > 40) _orders = _orders.slice(-40);
    _lastPlaceTick = s.tickCount;
  }

  function computeNetPressure(s) {
    // Calcule la pression nette (delta prix) exercée par tous les ordres LiqAI
    // en fonction de la distance au prix courant.
    // Les ordres proches exercent plus de pression (magnétisme ICT).
    const price = s.marketPrice, atr = s.ict.atr;
    const vol   = s.dynamicDailyVolume;
    let buyPressure = 0, sellPressure = 0;
    for(const o of _orders) {
      if(o.triggered) continue;
      const dist = Math.abs(o.price - price);
      const norm = dist / Math.max(atr, 0.01);
      if(norm > 5) continue; // trop loin → pas d'effet
      // Magnétisme: exponentiel décroissant avec la distance
      const mag = Math.exp(-norm * 0.55);
      // Impact proportionnel au lot (sans cap)
      const notional = o.lots * CONTRACT_SIZE_OZ * o.price;
      const volRatio = notional / Math.max(vol, 1);
      // Impact prix = √(volRatio) × ATR × TICK_SCALE (Kyle's lambda)
      const rawImpact = Math.sqrt(volRatio) * atr * TICK_SCALE * K_TEMP;
      const capped = rawImpact * mag;
      if(o.side==='buy')  buyPressure  += capped;
      else                sellPressure += capped;
    }
    return buyPressure - sellPressure; // positif = pression haussière
  }

  function checkTriggered(s) {
    // Déclenche les ordres dont le prix est atteint
    const price = s.marketPrice;
    let triggered = false;
    for(const o of _orders) {
      if(o.triggered) continue;
      const hit = o.side==='buy'  ? price <= o.price + 0.05
                : o.side==='sell' ? price >= o.price - 0.05
                : false;
      if(hit) {
        o.triggered = true;
        _totalTriggered++;
        triggered = true;
        // Injecter l'impact de cet ordre dans le moteur de prix
        const notional = o.lots * CONTRACT_SIZE_OZ * o.price;
        const volRatio = notional / Math.max(s.dynamicDailyVolume, 1);
        const permanentImpact = K_PERM * volRatio * price;
        const tempImpact = K_TEMP * s.ict.atr * Math.sqrt(volRatio);
        const dir = o.side==='buy' ? 1 : -1;
        const totalImpact = (permanentImpact + tempImpact) * dir;
        _injectICTPriceDelta(totalImpact, 'LIQAI_'+o.type.toUpperCase()+'_TRIGGERED');
        adjustDynamicVolume('liqai_trigger_'+o.type, 1.0 + Math.sqrt(volRatio)*5, 40);
        // Trap phase: si l'ordre inducement est déclenché → préparer le reversal
        if(o.type==='inducement' && _trapPhase==='setup') {
          _trapPhase = 'reversal';
        }
      }
    }
    // Nettoyage des ordres déclenchés vieux
    _orders = _orders.filter(o => !o.triggered || (s.tickCount - o.tickCreated) < TICKS_PER_CANDLE*5);
    return triggered;
  }

  function tick(s) {
    _modeAge++;
    // Changement de mode?
    if(_modeAge >= _modeDuration) {
      _mode = pickMode(s);
      const [mn,mx] = MODE_DURATION[_mode];
      _modeDuration = mn + Math.random()*(mx-mn);
      _modeAge = 0;
      _trapPhase = 'setup';
    }
    // Placement d'ordres (toutes les _placeCooldown bougies simulées)
    const candlesSinceLast = (s.tickCount - _lastPlaceTick) / TICKS_PER_CANDLE;
    const cooldown = _placeCooldown + (_mode==='trap' ? 2 : 0);
    if(candlesSinceLast >= cooldown || _orders.filter(o=>!o.triggered).length < 2) {
      placeOrders(s);
    }
    // Déclenchement
    checkTriggered(s);
    return computeNetPressure(s);
  }

  function getOrders()    { return _orders.filter(o=>!o.triggered); }
  function getMode()      { return _mode; }
  function getTrapPhase() { return _trapPhase; }
  function getTriggered() { return _totalTriggered; }
  function reset() {
    _orders=[]; _modeAge=0; _mode='range'; _lastPlaceTick=-999;
    _modeDuration=12; _totalTriggered=0; _trapPhase='setup';
  }

  return { tick, getOrders, getMode, getTrapPhase, getTriggered, reset };
})();


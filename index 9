  // EQH/EQL
  s.equalHighs.filter(e=>!e.swept).forEach(e=>{const y=yP(e.price);ctx.strokeStyle='rgba(245,158,11,0.75)';ctx.lineWidth=1.2;ctx.setLineDash([4,3]);ctx.beginPath();ctx.moveTo(lP,y);ctx.lineTo(lP+plW,y);ctx.stroke();ctx.setLineDash([]);ctx.fillStyle='rgba(245,158,11,0.85)';ctx.font='bold 8px monospace';ctx.textAlign='right';ctx.fillText('EQH',lP+plW-2,y-2);});

function updateMomentumGuard(delta) {
  const mg = state.momentumGuard;
  const dir = delta>0?1:delta<0?-1:0;
  if(dir!==0) {
    if(dir===mg.lastDir) { mg.consecutiveSameDir++; mg.cumulMoveFromAnchor+=Math.abs(delta); }
    else { mg.consecutiveSameDir=Math.max(0,mg.consecutiveSameDir-3); mg.cumulMoveFromAnchor*=0.70; mg.anchorPrice=state.marketPrice; mg.lastDir=dir; }
  }
  dir===1  ? (mg.pumpPressure=clamp(mg.pumpPressure+0.04,0,1), mg.dumpPressure=Math.max(0,mg.dumpPressure-0.02))
           : dir===-1 ? (mg.dumpPressure=clamp(mg.dumpPressure+0.04,0,1), mg.pumpPressure=Math.max(0,mg.pumpPressure-0.02)) : null;
  mg.pumpPressure*=0.992; mg.dumpPressure*=0.992;
  if(state.marketPrice > mg.dailyHighFromOpen) mg.dailyHighFromOpen=state.marketPrice;
  if(state.marketPrice < mg.dailyLowFromOpen)  mg.dailyLowFromOpen=state.marketPrice;
  if((state.tickCount-mg.dayStartTick)>240*TICKS_PER_CANDLE) {
    mg.dayStartTick=state.tickCount; mg.dailyOpenPrice=state.marketPrice;
    mg.dailyHighFromOpen=state.marketPrice; mg.dailyLowFromOpen=state.marketPrice;
  }
}

function computeMomentumBrake() {
  const mg = state.momentumGuard, atr = state.ict.atr;
  let brake = 0;
  if(mg.consecutiveSameDir > MR_THRESHOLD) {
    const excess=mg.consecutiveSameDir-MR_THRESHOLD;
    if(Math.random() < clamp(excess*0.04,0,0.65)) {
      brake += -mg.lastDir * atr * TICK_SCALE * clamp(excess*0.03,0.08,0.35);
      mg.consecutiveSameDir=Math.max(0,mg.consecutiveSameDir-6);
    }
  }
  if(mg.cumulMoveFromAnchor > atr*1.8) {
    brake += clamp(-mg.lastDir*(mg.cumulMoveFromAnchor-atr*1.8)*0.15*TICK_SCALE, -atr*TICK_SCALE*0.25, atr*TICK_SCALE*0.25);
  }
  if(mg.pumpPressure>0.5) brake += -(mg.pumpPressure-0.5)*atr*TICK_SCALE*0.18;
  if(mg.dumpPressure>0.5) brake +=  (mg.dumpPressure-0.5)*atr*TICK_SCALE*0.18;
  const daily=mg.dailyHighFromOpen-mg.dailyLowFromOpen;
  if(daily > atr*4.5) {
    const mid=(mg.dailyHighFromOpen+mg.dailyLowFromOpen)/2;
    brake += clamp(-(state.marketPrice-mid)*0.008*DRIFT_SCALE, -atr*TICK_SCALE*0.20, atr*TICK_SCALE*0.20);
  }
  return clamp(brake, -atr*TICK_SCALE*0.50, atr*TICK_SCALE*0.50);
}


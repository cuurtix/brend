function computeProfile(candles, extra={}){ if(!candles.length) return {...DEFAULT_PROFILE,source:'Défaut'}; const rets=[],wR=[],bR=[],uR=[],lR=[]; let up=0; for(let i=0;i<candles.length;i++){ const c=candles[i]; const range=Math.max(c.high-c.low,0.000001); const body=Math.abs(c.close-c.open); wR.push((range-body)/range); bR.push(body/range); uR.push((c.high-Math.max(c.open,c.close))/range); lR.push((Math.min(c.open,c.close)-c.low)/range); if(i>0){ const r=Math.log(c.close/candles[i-1].close); if(Number.isFinite(r)) rets.push(r); if(c.close>candles[i-1].close) up++; } } const sigma=Math.sqrt(mean(rets.map(r=>r*r))); let atrSum=0; for(let i=1;i<candles.length;i++) atrSum+=Math.max(candles[i].high-candles[i].low,Math.abs(candles[i].high-candles[i-1].close),Math.abs(candles[i].low-candles[i-1].close)); const avgATR=candles.length>1?atrSum/(candles.length-1):DEFAULT_PROFILE.sigma1mPct*START_PRICE*2.4; return { source:extra.source||'calibré', midPrice:candles[candles.length-1].close, sigma1mPct:clamp(sigma||DEFAULT_PROFILE.sigma1mPct,0.00010,0.00400), wickRatio:clamp(median(wR)||DEFAULT_PROFILE.wickRatio,0.25,0.80), bodyRatio:clamp(median(bR)||DEFAULT_PROFILE.bodyRatio,0.20,0.75), upperWickRatio:clamp(median(uR)||0.24,0.05,0.50), lowerWickRatio:clamp(median(lR)||0.24,0.05,0.50), medianSpread:clamp(extra.medianSpread||0.18,0.04,2.0), trendPersistence:clamp(up/Math.max(rets.length,1)*0.5+0.30,0.40,0.65), orderFlowBias:0, liquidityUSD:XAUUSD_BASE_MIN, median1mQuoteVolume:XAUUSD_BASE_MIN, avgRun:5.0, microNoise:clamp(median(wR)*0.7,0.12,1.0), profileStrength:Math.min(1,candles.length/500), dailyATRTarget:clamp(avgATR*Math.sqrt(Math.min(candles.length,1440)),5,60), }; }
function mergeProfiles(datasets){ const pool=[]; datasets.forEach(ds=>{ if(ds.candles?.length) pool.push(...ds.candles); }); pool.sort((a,b)=>a.time-b.time); return computeProfile(pool.slice(-4000),{source:`calibré (${datasets.length} ds)`}); }

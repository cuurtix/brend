    const typeColor = o.type==='inducement' ? 'rgba(124,58,237,0.80)' : o.side==='buy' ? modeCol+'0.70)' : modeCol.replace(modeCol,modeColors.bear)+'0.70)';
    ctx.strokeStyle = typeColor;
    ctx.lineWidth = clamp(1.2 + Math.log10(Math.max(o.lots,1))*0.4, 1.2, 3.5);
    ctx.setLineDash(dashMap[o.type]||[4,3]);
    ctx.beginPath(); ctx.moveTo(lP, y); ctx.lineTo(lP+plW, y); ctx.stroke(); ctx.setLineDash([]);
    // Label

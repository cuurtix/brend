function updateOrderBook(){ const of=state.orderflow,ict=state.ict; for(let i=0;i<5;i++){ of.bid_depth[i]=Math.min(1,of.bid_depth[i]+0.015*(1-of.bid_depth[i])); of.ask_depth[i]=Math.min(1,of.ask_depth[i]+0.015*(1-of.ask_depth[i])); } const tb=of.bid_depth.reduce((a,b)=>a+b,0)/5,ta=of.ask_depth.reduce((a,b)=>a+b,0)/5; of.imbalance_ratio=(tb-ta)*0.5; const md=ict.consecutive_moves*ict.last_move_dir; of.delta=clamp(md/10,-1,1); of.cumulDelta=clamp(of.cumulDelta*0.98+of.delta*0.02,-1,1); of.buy_pressure=clamp(0.5+of.imbalance_ratio*0.18+state.structure.bias*0.10+of.cumulDelta*0.07,0.15,0.85); of.sell_pressure=1-of.buy_pressure; of.exhaustion=clamp(Math.abs(md)/14,0,1); const bs=state.referenceProfile.medianSpread||0.18; const vf=ict.vol_regime==='EXPANSION'?2.6:ict.vol_regime==='HIGH'?1.8:ict.vol_regime==='COMPRESSION'?0.7:1.0; const pf=1+state.panic.level*3; const sf=ict.session==='ASIA'?1.4:ict.session==='NY_OPEN'?0.85:1.0; state.spread=clamp(bs*vf*pf*sf,0.04,10.0); }

function updateICTMetrics(){ const r=state.candles.slice(-10); if(r.length>=2){ let up=0; for(let i=1;i<r.length;i++) if(r[i].close>r[i-1].close) up++; state.ict.imbalance=(up-(r.length-up))/r.length; } const ar=state.ict.atr/Math.max(state.ict.atr_slow,0.001); state.ict.vol_regime=ar>1.7?'EXPANSION':ar>1.25?'HIGH':ar<0.65?'COMPRESSION':ar<0.82?'LOW':'NORMAL'; const s=state.structure,range=s.swingHigh-s.swingLow; state.ict.ote_level=s.phase==='uptrend'?s.swingHigh-range*0.705:s.phase==='downtrend'?s.swingLow+range*0.705:s.equilibrium; }


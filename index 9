      ctx.beginPath(); ctx.moveTo(lP+plW-16,y); ctx.lineTo(lP+plW-10,y-5); ctx.lineTo(lP+plW-4,y); ctx.lineTo(lP+plW-10,y+5); ctx.closePath(); ctx.fill();
    }
  }

  // Bougies
  data.forEach((c,i)=>{const x=lP+i*sp+sp/2,yO=yP(c.open),yC=yP(c.close),yH=yP(c.high),yL=yP(c.low),bull=c.close>=c.open;ctx.strokeStyle=bull?'#0a7d38':'#7a1a1a';ctx.lineWidth=Math.max(1,cW*0.15);ctx.beginPath();ctx.moveTo(x,yH);ctx.lineTo(x,yL);ctx.stroke();const bH=Math.max(1.5,Math.abs(yC-yO));ctx.fillStyle=bull?'#12a150':'#af1f1f';ctx.strokeStyle='rgba(0,0,0,0.35)';ctx.lineWidth=0.8;ctx.fillRect(x-cW/2,Math.min(yO,yC),cW,bH);ctx.strokeRect(x-cW/2,Math.min(yO,yC),cW,bH);});
  // Prix live
  const lpY=yP(state.marketPrice);ctx.setLineDash([4,4]);ctx.strokeStyle='#111';ctx.lineWidth=1.8;ctx.beginPath();ctx.moveTo(lP,lpY);ctx.lineTo(lP+plW,lpY);ctx.stroke();ctx.setLineDash([]);ctx.fillStyle='#111';ctx.fillRect(lP+plW+4,lpY-12,rG-10,22);ctx.fillStyle='#fff';ctx.font='bold 11px monospace';ctx.textAlign='left';ctx.fillText(state.marketPrice.toFixed(2),lP+plW+8,lpY+4);
  // Positions joueur
  state.positions.forEach(pos=>{const y=yP(pos.entryPrice);ctx.strokeStyle=pos.side==='buy'?'rgba(18,161,80,0.85)':'rgba(175,31,31,0.85)';ctx.lineWidth=1.5;ctx.setLineDash([5,3]);ctx.beginPath();ctx.moveTo(lP,y);ctx.lineTo(lP+plW,y);ctx.stroke();ctx.setLineDash([]);if(pos.stopLoss){const ySL=yP(pos.stopLoss);ctx.strokeStyle='rgba(175,31,31,0.5)';ctx.lineWidth=1;ctx.setLineDash([2,3]);ctx.beginPath();ctx.moveTo(lP,ySL);ctx.lineTo(lP+plW,ySL);ctx.stroke();ctx.setLineDash([]);}if(pos.takeProfit){const yTP=yP(pos.takeProfit);ctx.strokeStyle='rgba(18,161,80,0.5)';ctx.lineWidth=1;ctx.setLineDash([2,3]);ctx.beginPath();ctx.moveTo(lP,yTP);ctx.lineTo(lP+plW,yTP);ctx.stroke();ctx.setLineDash([]);}});
  // Time axis
  ctx.fillStyle='#666';ctx.font='9px monospace';ctx.textAlign='center';const slT=Math.max(1,Math.floor(data.length/8));for(let i=0;i<data.length;i+=slT){const x=lP+i*sp+sp/2;ctx.fillText(new Date(data[i].time).toLocaleTimeString('fr-FR',{hour:'2-digit',minute:'2-digit'}),x,h-6);}

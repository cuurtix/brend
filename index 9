.symbol{font-size:22px;font-weight:900;letter-spacing:.03em;}.spot-price{font-size:32px;font-weight:900;text-align:center;}.subprice{text-align:center;color:var(--muted);font-size:12px;margin-top:2px;}
.chart-wrap{position:relative;padding:12px 14px 8px;background:linear-gradient(180deg,#fff,#f1f1f1);border-bottom:2px solid #111;}
#canvas_chart{width:100%;height:520px;display:block;background:linear-gradient(180deg,rgba(0,0,0,.01),rgba(0,0,0,.005)),repeating-linear-gradient(to bottom,transparent 0 60px,rgba(0,0,0,.04) 60px 61px),repeating-linear-gradient(to right,transparent 0 70px,rgba(0,0,0,.03) 70px 71px);border:2px solid #111;border-radius:12px;cursor:crosshair;}
.controls-strip{display:grid;grid-template-columns:repeat(6,minmax(0,1fr));gap:8px;padding:10px 14px;border-top:2px solid #111;background:#f8f8f8;}
.stat-card{border:2px solid #111;border-radius:12px;background:white;padding:8px;min-height:78px;}
.stat-label{color:var(--muted);font-size:11px;text-transform:uppercase;font-weight:700;}.stat-value{margin-top:4px;font-size:18px;font-weight:900;}.stat-sub{margin-top:2px;font-size:11px;color:#666;}

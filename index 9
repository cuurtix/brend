// TRADING & POSITIONS — impact illimité proportionnel
// ═══════════════════════════════════════════════════════════
function computeOrderMetrics(priceOverride){
  const lots=Math.max(Number(dom.lotsInput.value||0),0.01);
  const lev=Math.max(Number(state.selectedLeverage||1),1);
  const half=state.spread/2;
  const execBase=priceOverride!==undefined?priceOverride:state.marketPrice+(state.direction==='buy'?half:-half);
  const notional=lots*CONTRACT_SIZE_OZ*execBase;
  const volRatio=notional/Math.max(state.dynamicDailyVolume,1);
  const label=classifyImpact(volRatio);
  // Impact illimité: linéaire avec le lot
  const permImpact = K_PERM * volRatio * execBase;
  const tempImpact = K_TEMP * state.ict.atr * Math.sqrt(volRatio);
  const totalImpact = permImpact + tempImpact;
  const exec=execBase+(state.direction==='buy'?totalImpact:-totalImpact);
  return {lots,lev,notional,margin:notional/lev,impact:totalImpact,exec,dollarPerMove:lots*CONTRACT_SIZE_OZ,volRatio,label};
}

function updatePreview(){
  const m=computeOrderMetrics(state.orderType!=='market'&&state.pendingPrice?state.pendingPrice:undefined);
  dom.previewNotional.textContent=fmtMoney(m.notional);
  dom.previewMargin.textContent=fmtMoney(m.margin);
  dom.previewImpact.textContent=`${m.impact>=0?'+':''}${m.impact.toFixed(4)} $ (${m.label})`;
  dom.previewDollarMove.textContent=fmtMoney(m.dollarPerMove);
  dom.previewExecution.textContent=fmtPrice(m.exec);
  dom.previewVolRatio.textContent=`${(m.volRatio*100).toFixed(6)}% vol`;
}

function recalcAccount(){ let fl=0,mg=0; for(const p of state.positions){const pnl=p.side==='buy'?(state.marketPrice-p.entryPrice)*CONTRACT_SIZE_OZ*p.lots:(p.entryPrice-state.marketPrice)*CONTRACT_SIZE_OZ*p.lots;p.floatingPnl=pnl;fl+=pnl;mg+=p.marginUsed;} state.floatingPnl=fl;state.usedMargin=mg;state.equity=state.balance+fl;state.freeFunds=Math.max(state.equity-state.usedMargin,0); }

function openPosition(priceOverride){
  const m=computeOrderMetrics(priceOverride);
  if(m.margin>state.freeFunds) return showToast('⛔ Fonds insuffisants');
  const pos={id:state.nextPositionId++,side:state.direction,lots:m.lots,entryPrice:m.exec,stopLoss:dom.slInput.value?Number(dom.slInput.value):null,takeProfit:dom.tpInput.value?Number(dom.tpInput.value):null,marginUsed:m.margin,floatingPnl:0,openTick:state.tickCount,impactLabel:m.label};
  state.positions.push(pos);
  const pm=state.playerMarketInfluence;
  pm.recentOrderHistory.push({side:state.direction,price:m.exec,lots:m.lots,time:state.tickCount});
  if(pm.recentOrderHistory.length>10) pm.recentOrderHistory.shift();
  if(state.direction==='buy') pm.recentBuyPressure+=m.volRatio*1000; else pm.recentSellPressure+=m.volRatio*1000;
  // Impact illimité: inject proportionnel au lot
  const dir=state.direction==='buy'?1:-1;
  _injectICTPriceDelta(dir*m.impact*0.50,'PLAYER_ORDER_'+m.label.toUpperCase());
  const bookImpact=m.volRatio*5;
  if(state.direction==='buy') state.orderflow.bid_depth[0]=Math.max(0.10,state.orderflow.bid_depth[0]-bookImpact);
  else state.orderflow.ask_depth[0]=Math.max(0.10,state.orderflow.ask_depth[0]-bookImpact);
  adjustDynamicVolume('player_order',1.0+Math.sqrt(m.volRatio)*8,30);
  recalcAccount(); renderAll();
  showToast(`✅ ${pos.side==='buy'?'LONG':'SHORT'} ${m.lots}L @ ${fmtPrice(m.exec)} [${m.label}]`);
}

function placePendingOrder(){
  const tp=state.pendingPrice; if(!tp||tp<=0) return showToast('⛔ Prix invalide');
  const m=computeOrderMetrics(tp); if(m.margin>state.freeFunds) return showToast('⛔ Fonds insuffisants');
  const po={id:state.nextPendingId++,type:state.orderType,side:state.direction,lots:m.lots,triggerPrice:tp,price:tp,stopLoss:dom.slInput.value?Number(dom.slInput.value):null,takeProfit:dom.tpInput.value?Number(dom.tpInput.value):null,marginReserved:m.margin};
  state.pendingOrders.push(po); state.freeFunds=Math.max(state.freeFunds-m.margin,0);
  recalcAccount(); renderAll();
  showToast(`⏳ ${po.type.toUpperCase()} ${po.side==='buy'?'BUY':'SELL'} @ ${fmtPrice(tp)}`);
}

function checkPendingOrders(){ const price=state.marketPrice; const toTrig=[]; for(const po of state.pendingOrders){ let hit=false; if(po.type==='limit'){if(po.side==='buy'&&price<=po.triggerPrice) hit=true;if(po.side==='sell'&&price>=po.triggerPrice) hit=true;} else if(po.type==='stop'||po.type==='stop_limit'){if(po.side==='buy'&&price>=po.triggerPrice) hit=true;if(po.side==='sell'&&price<=po.triggerPrice) hit=true;} if(hit) toTrig.push(po);} for(const po of toTrig){ state.pendingOrders=state.pendingOrders.filter(p=>p.id!==po.id); state.freeFunds=Math.min(state.freeFunds+po.marginReserved,state.equity); const sd=state.direction,sl=dom.lotsInput.value,ss=dom.slInput.value,st=dom.tpInput.value; state.direction=po.side;dom.lotsInput.value=po.lots;dom.slInput.value=po.stopLoss||'';dom.tpInput.value=po.takeProfit||''; openPosition(po.triggerPrice); state.direction=sd;dom.lotsInput.value=sl;dom.slInput.value=ss;dom.tpInput.value=st; showToast(`🎯 ${po.type.toUpperCase()} déclenché @ ${po.triggerPrice.toFixed(2)}`);} }

window.closePosition=function(id){ const idx=state.positions.findIndex(p=>p.id===id); if(idx===-1) return; const pos=state.positions[idx]; const half=state.spread/2; const exitPrice=state.marketPrice+(pos.side==='buy'?-half:half); const pnl=pos.side==='buy'?(exitPrice-pos.entryPrice)*CONTRACT_SIZE_OZ*pos.lots:(pos.entryPrice-exitPrice)*CONTRACT_SIZE_OZ*pos.lots; state.balance+=pnl; state.positions.splice(idx,1); adjustDynamicVolume('pos_close',0.97,30); recalcAccount(); renderAll(); showToast(`Fermée: ${fmtMoney(pnl)}`); };
window.cancelPendingOrder=function(id){ const idx=state.pendingOrders.findIndex(p=>p.id===id); if(idx===-1) return; const po=state.pendingOrders[idx]; state.freeFunds=Math.min(state.freeFunds+po.marginReserved,state.equity); state.pendingOrders.splice(idx,1); recalcAccount(); renderAll(); showToast('Ordre annulé'); };
function closeAllPositions(){ [...state.positions.map(p=>p.id)].forEach(id=>closePosition(id)); [...state.pendingOrders.map(p=>p.id)].forEach(id=>cancelPendingOrder(id)); }
function applyStopLosses(){ state.positions.forEach(pos=>{ const hitSL=pos.stopLoss&&((pos.side==='buy'&&state.marketPrice<=pos.stopLoss)||(pos.side==='sell'&&state.marketPrice>=pos.stopLoss)); const hitTP=pos.takeProfit&&((pos.side==='buy'&&state.marketPrice>=pos.takeProfit)||(pos.side==='sell'&&state.marketPrice<=pos.takeProfit)); if(hitSL){adjustDynamicVolume('sl_hit',1.3,30);closePosition(pos.id);}else if(hitTP) closePosition(pos.id); }); }


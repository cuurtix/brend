.zoom-controls{display:flex;gap:4px;align-items:center;padding:6px;border:2px solid #111;border-radius:12px;background:white;}
.zoom-btn{min-width:40px;padding:6px 8px;font-size:12px;font-weight:700;}.zoom-level{font-weight:700;min-width:50px;text-align:center;font-size:12px;}
.main{display:grid;grid-template-columns:1fr 400px;min-height:900px;}

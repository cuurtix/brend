    ctx.font = 'bold 8px monospace'; ctx.textAlign = 'left';
    const typeLabel = { bsl:'BSL', ssl:'SSL', ob:'OB', fvg:'FVG', inducement:'IND' }[o.type]||o.type;
    const lotsLabel = o.lots >= 1000 ? `${(o.lots/1000).toFixed(1)}KL` : o.lots >= 100 ? `${(o.lots/100).toFixed(1)}HL` : `${o.lots.toFixed(0)}L`;
    ctx.fillText(`${o.side==='buy'?'↑':'↓'}${typeLabel} ${lotsLabel}`, lP+4, o.side==='buy'?y-2:y+9);
    // Diamant si très gros lot
    if(o.lots > 200) {

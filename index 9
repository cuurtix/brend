  if(s.sweepInProgress){const y=yP(s.sweepTarget||state.marketPrice);ctx.strokeStyle='rgba(245,158,11,0.9)';ctx.lineWidth=1.5;ctx.setLineDash([3,2]);ctx.beginPath();ctx.moveTo(lP,y);ctx.lineTo(lP+plW,y);ctx.stroke();ctx.setLineDash([]);ctx.fillStyle='rgba(245,158,11,0.9)';ctx.font='bold 9px monospace';ctx.textAlign='left';ctx.fillText('SWEEP',lP+4,y+(s.sweepDir>0?-3:10));}

  // ── ORDRES LiqAI (visibles sur le graphe) ────────────
  const modeColors = { bull:'rgba(18,161,80,', bear:'rgba(175,31,31,', range:'rgba(37,99,235,', trap:'rgba(124,58,237,' };
  const modeCol = modeColors[LiquidityAI.getMode()] || 'rgba(100,100,100,';
  for(const o of LiquidityAI.getOrders()) {
    const y = yP(o.price);
    if(y < tP-20 || y > tP+plH+20) continue;
    // Ligne horizontale avec style selon type

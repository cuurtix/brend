.shell{max-width:1920px;margin:0 auto;background:linear-gradient(180deg,#f7f7f7,#ececec);border:2px solid #111;border-radius:14px;box-shadow:var(--shadow);overflow:hidden;}
.topbar{display:grid;grid-template-columns:320px 1fr 320px 160px;gap:12px;align-items:center;padding:14px 16px 10px;border-bottom:2px solid #111;background:#f4f4f4;}

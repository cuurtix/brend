function adjustDynamicVolume(reason, mult, dur) {
  const base = XAUUSD_BASE_DAILY;
  const cur = state.dynamicDailyVolume / base;
  const nxt = clamp(cur*0.7 + mult*0.3, 0.4, 8.0);
  state.dynamicDailyVolume = base * nxt;
  state.dynamicMinuteVolume = state.dynamicDailyVolume / 1440;
  state.volumeEvents.push({tick:state.tickCount,reason,mult:nxt,decay:dur||80});
  if(state.volumeEvents.length>20) state.volumeEvents.shift();
}
function decayDynamicVolume() {
  const target = XAUUSD_BASE_DAILY * (state.sessionBias||1.0);
  state.dynamicDailyVolume = ema(state.dynamicDailyVolume, target, 0.004);
  state.dynamicMinuteVolume = state.dynamicDailyVolume / 1440;
}
function getVolRatio() { return state.dynamicDailyVolume / XAUUSD_BASE_DAILY; }

// ═══════════════════════════════════════════════════════════
// IMPACT JOUEUR — ILLIMITÉ & LINÉAIRE
// ═══════════════════════════════════════════════════════════
function computePlayerExposure() {
  let notional = 0;
  for(const p of state.positions) notional += p.lots * CONTRACT_SIZE_OZ * p.entryPrice;
  for(const p of state.pendingOrders) notional += p.lots * CONTRACT_SIZE_OZ * (p.triggerPrice||state.marketPrice);
  return notional / Math.max(state.dynamicDailyVolume, 1);
}

function evaluateExecQuality(pos) {
  let q = 1.0;
  const bias = state.structure.bias, mom = state.ict.consecutive_moves;
  if(pos.side==='buy'  && bias<-0.35) q -= 0.30;
  if(pos.side==='sell' && bias> 0.35) q -= 0.30;
  if(mom > 10) q -= 0.20;
  if(!pos.stopLoss) q -= 0.15;
  const r = (pos.lots * CONTRACT_SIZE_OZ * pos.entryPrice) / Math.max(state.balance, 1);
  if(r > 0.5) q -= 0.20;
  if(r > 1.0) q -= 0.20;
  return clamp(q, 0, 1.0);
}

function updatePlayerInfluence() {
  const pm = state.playerMarketInfluence;
  if(pm.stopHuntCooldown > 0) pm.stopHuntCooldown--;
  const ratio = computePlayerExposure();
  pm.exposureRatio = ratio;
  pm.impactLabel   = classifyImpact(ratio);
  pm.isVisible     = ratio >= IMPACT_MARGINAL;
  let netBias = 0;
  for(const p of state.positions) {
    const w = (p.lots * CONTRACT_SIZE_OZ * p.entryPrice) / Math.max(state.dynamicDailyVolume, 1);
    netBias += (p.side==='buy'?1:-1) * w;
  }
  // Biais normalisé — peut dépasser 1 si whale
  pm.netDirectionalBias = netBias / Math.max(IMPACT_MODERATE, 0.0001);
  pm.executionQuality = state.positions.length ? mean(state.positions.map(evaluateExecQuality)) : 1.0;
  const bias = state.structure.bias;
  pm.isAgainstTrend = (pm.netDirectionalBias > 0.2 && bias < -0.3) || (pm.netDirectionalBias < -0.2 && bias > 0.3);
  pm.recentBuyPressure  *= 0.92;
  pm.recentSellPressure *= 0.92;
  // Stop hunt possible si exposé ET mauvaise exécution ET SL accessible
  const hasSLNear = state.positions.some(p => {
    if(!p.stopLoss) return false;
    return Math.abs(state.marketPrice - p.stopLoss) < state.ict.atr * 1.5;
  });
  pm.isStopHuntTarget = pm.isVisible && pm.stopHuntCooldown===0 && hasSLNear && pm.executionQuality < 0.55;
}

// Pression prix joueur: ILLIMITÉE — proportionnelle au lot/volume
function computePlayerPricePressure() {
  const pm = state.playerMarketInfluence;
  if(!pm.isVisible && pm.exposureRatio < IMPACT_NONE) return 0;
  const atr = state.ict.atr;
  const r = pm.exposureRatio;
  const dir = Math.sign(pm.netDirectionalBias);
  // Impact = K_TEMP × ATR × √(ratio) × TICK_SCALE — sans cap sur le ratio
  const rawPressure = dir * K_TEMP * atr * Math.sqrt(r) * TICK_SCALE * 0.30;
  // Permanent: déplace le prix dans la direction de la position nette
  return rawPressure; // peut être très fort si whale
}

function attemptPlayerStopHunt() {
  const pm = state.playerMarketInfluence;
  if(!pm.isStopHuntTarget || pm.stopHuntCooldown > 0) return 0;
  if(state.tickCount - pm.lastStopHuntTick < 400) return 0;
  const prob = STOP_HUNT_BASE * clamp(1.5 - pm.executionQuality*1.5, 0.1, 2) * clamp(pm.exposureRatio/IMPACT_MODERATE, 0.1, 5) * (pm.isAgainstTrend?2:1);
  if(Math.random() > prob) return 0;
  let bestPos = null, bestDist = Infinity;
  for(const p of state.positions) {
    if(!p.stopLoss) continue;
    const d = Math.abs(state.marketPrice - p.stopLoss);
    if(d < bestDist) { bestDist=d; bestPos=p; }
  }
  if(!bestPos) return 0;
  const huntDir = bestPos.side==='buy' ? -1 : 1;
  const atr = state.ict.atr;

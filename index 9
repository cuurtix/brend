*{box-sizing:border-box;}html,body{margin:0;font-family:'SF Mono','Monaco','Menlo',monospace;background:#dcdcdc;color:var(--text);}
button,input,select,textarea{font:inherit;}
button{transition:transform .06s ease,box-shadow .12s ease,background .12s ease;box-shadow:0 3px 0 #111;border:2px solid #111;border-radius:12px;padding:10px 14px;cursor:pointer;font-weight:700;background:white;}
button:hover{transform:translateY(-1px);filter:brightness(.98);}button:active{transform:translateY(2px);box-shadow:0 1px 0 #111;}button:disabled{opacity:.6;cursor:not-allowed;}

function computeOBMag(){ const p=state.marketPrice,atr=state.ict.atr; let m=0; for(const z of state.structure.demandZones.filter(z=>!z.broken&&z.high<p)){ const n=(p-z.mid)/Math.max(atr,0.01); if(n<2) m+=z.strength*0.004*(1-n/2)*atr; } for(const z of state.structure.supplyZones.filter(z=>!z.broken&&z.low>p)){ const n=(z.mid-p)/Math.max(atr,0.01); if(n<2) m-=z.strength*0.004*(1-n/2)*atr; } return clamp(m,-atr*0.05,atr*0.05); }

function updateSweep(){ const s=state.structure,atr=state.ict.atr,price=state.marketPrice,of=state.orderflow; if(s.sweepInProgress){ s.sweepTick++; const beyond=s.sweepDir===1?price>s.sweepTarget+atr*0.05:price<s.sweepTarget-atr*0.05; if(beyond||s.sweepTick>25){ s.sweepInProgress=false; const rev=-s.sweepDir; _injectICTPriceDelta(rev*atr*0.35,'SWEEP_REV'); of.pending_impact+=rev*atr*0.45; s.bias=clamp(s.bias+rev*0.30,-1,1); s.lastSweepPnl=s.sweepDir>0?price-s.sweepStartPrice:s.sweepStartPrice-price; if(s.sweepDir===1) s.equalHighs.forEach(e=>{if(Math.abs(e.price-s.sweepTarget)<atr*0.3) e.swept=true;}); else s.equalLows.forEach(e=>{if(Math.abs(e.price-s.sweepTarget)<atr*0.3) e.swept=true;}); adjustDynamicVolume('sweep_done',1.8,80); } else _injectICTPriceDelta(s.sweepDir*atr*0.025,'SWEEP_PUSH'); return; } const prob=(s.phase==='range'?0.0010:s.phase==='compression'?0.0007:0.0003)*Math.min(getVolRatio(),2); if(Math.random()<prob){ const bP=s.equalHighs.filter(e=>!e.swept&&e.price>price&&e.price<price+atr*4); const bN=s.equalLows.filter(e=>!e.swept&&e.price<price&&e.price>price-atr*4); if(s.bias>0.05&&bP.length){ const t=bP.sort((a,b)=>a.price-b.price)[0].price; s.sweepInProgress=true;s.sweepDir=1;s.sweepTarget=t;s.sweepStartPrice=price;s.sweepTick=0; _injectICTPriceDelta(+atr*0.35,'SWEEP_BULL'); adjustDynamicVolume('sweep_bull',2.5,40); } else if(s.bias<-0.05&&bN.length){ const t=bN.sort((a,b)=>b.price-a.price)[0].price; s.sweepInProgress=true;s.sweepDir=-1;s.sweepTarget=t;s.sweepStartPrice=price;s.sweepTick=0; _injectICTPriceDelta(-atr*0.35,'SWEEP_BEAR'); adjustDynamicVolume('sweep_bear',2.5,40); } } }

function updateMarketStructure(){ const s=state.structure,atr=state.ict.atr; const range=Math.max(s.swingHigh-s.swingLow,atr*0.1); s.equilibrium=(s.swingHigh+s.swingLow)/2; s.premium=s.swingLow+range*0.705; s.discount=s.swingLow+range*0.295; const relRange=range/(atr*10||1); const bias=s.bias; s.phase=Math.abs(bias)>0.50?(bias>0?'uptrend':'downtrend'):relRange<0.65?'compression':relRange>1.8?'expansion':'range'; s.bias=clamp(s.bias*0.9990,-1,1); s.bosStrength*=0.97; s.chochStrength*=0.96; detectSwings(3); detectBOSChoCH(); detectFVGs(); detectEQHL(); detectOB(); updateSweep(); }

